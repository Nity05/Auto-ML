\nprice_pipeline = Pipeline([\n    ('price_cleaner', PriceCleaner()),\n    ('imputer', SimpleImputer(strategy='median')),\n    ('scaler', StandardScaler())\n])\n\ndate_pipeline = Pipeline([\n    ('date_extractor', DateFeatureExtractor()),\n    ('imputer', SimpleImputer(strategy='median')),\n    ('scaler', StandardScaler())\n])\n\nvolume_pipeline = Pipeline([\n    ('imputer', SimpleImputer(strategy='median')),\n    ('scaler', StandardScaler())\n])\n\npreprocessor = ColumnTransformer(\n    transformers=[\n        ('price', price_pipeline, price_cols),\n        ('date', date_pipeline, date_col),\n        ('volume', volume_pipeline, volume_col)\n    ],\n    remainder='passthrough'\n)\n\nmodel = RandomForestClassifier(n_estimators=100, random_state=42)\n\nfull_pipeline = Pipeline(steps=[\n    ('preprocessor', preprocessor),\n    ('classifier', model)\n])\n\nfull_pipeline.fit(X_train, y_train)\n\ny_pred = full_pipeline.predict(X_test)\n\naccuracy = accuracy_score(y_test, y_pred)\nclass_report = classification_report(y_test, y_pred, target_names=target_names)\n\nprint(f\"Accuracy: {accuracy}\")\nprint(\"\\nClassification Report:\")\nprint(class_report)","status":"success","target":"Company","target_source":"auto","task":"classification"}
